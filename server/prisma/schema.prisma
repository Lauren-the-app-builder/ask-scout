generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  tasteProfile TasteProfile?
  userBooks    UserBook[]
  readLogs     ReadLog[]
  chatMessages ChatMessage[]
}

model TasteProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  lovedAuthors    String   @default("[]")
  dislikedAuthors String   @default("[]")
  lovedGenres     String   @default("[]")
  lovedThemes     String   @default("[]")
  avoidThemes     String   @default("[]")
  notes           String   @default("")
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Book {
  id            String  @id @default(cuid())
  title         String
  author        String
  year          Int?
  isbn          String? @unique
  coverUrl      String?
  genre         String?
  description   String?
  googleBooksId String? @unique

  userBooks    UserBook[]
  readLogs     ReadLog[]
  chatMessages ChatMessage[]
}

model UserBook {
  id      String   @id @default(cuid())
  userId  String
  bookId  String
  status  String   @default("buy")
  order   Int      @default(0)
  addedAt DateTime @default(now())
  readAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model ReadLog {
  id     String   @id @default(cuid())
  userId String
  bookId String
  readAt DateTime @default(now())
  rating String?
  notes  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id           String   @id @default(cuid())
  userId       String
  role         String
  content      String
  createdAt    DateTime @default(now())
  linkedBookId String?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedBook Book? @relation(fields: [linkedBookId], references: [id])
}
